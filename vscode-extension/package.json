{
  "name": "vibe-diagnosis-vscode",
  "displayName": "Vibe Diagnosis",
  "description": "Self-diagnosis framework for vibe coding projects",
  "version": "1.0.0",
  "publisher": "Rejard",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "vibe-coding",
    "diagnosis",
    "testing",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rejard/vibe-diagnosis"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "workspaceContains:.vibe-diagnosis"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vibeDiagnosis.run",
        "title": "Vibe Diagnosis: Run"
      },
      {
        "command": "vibeDiagnosis.init",
        "title": "Vibe Diagnosis: Init"
      },
      {
        "command": "vibeDiagnosis.runJson",
        "title": "Vibe Diagnosis: Run (JSON)"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
